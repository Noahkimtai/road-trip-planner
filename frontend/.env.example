VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# OpenAI API Key for AI-powered recommendations
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here